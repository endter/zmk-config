/* KEY POSITIONS (using keypos_def helpers)
╭─────────────────────┬─────────────────────╮
│ LT4 LT3 LT2 LT1 LT0 │ RT0 RT1 RT2 RT3 RT4 │
│ LM4 LM3 LM2 LM1 LM0 │ RM0 RM1 RM2 RM3 RM4 │
│ LB4 LB3 LB2 LB1 LB0 │ RB0 RB1 RB2 RB3 RB4 │
╰───────╮ LH2 LH1 LH0 │ RH0 RH1 RH2 ╭───────╯
        ╰─────────────┴─────────────╯       */

#define COMBO(NAME, BINDINGS, KEYPOS, LAYERS, TERM, QUICKTAP, ...) \
  combo_##NAME { \
      timeout-ms = <TERM>; \
      bindings = <BINDINGS>; \
      key-positions = <KEYPOS>; \
      layers = <LAYERS>; \
      require-prior-idle-ms = <QUICKTAP>; \
      __VA_ARGS__ \
  };

/{
  combos {
    compatible = "zmk,combos";

    /* BILATERAL */
    COMBO(cmd_spc,           &kp LG(SPACE),      LM1 RM1,            BASE,              50,  100)
    COMBO(sft_cmd_spc,       &kp LSG(SPACE),     LM2 RM2,            BASE,              50,  100)
    COMBO(sft_alt_cmd_spc,   &kp LSAG(SPACE),    LM1 RM2,            BASE,              50,  100)

    /* LEFT-HAND HORIZONTAL */
    COMBO(F2,                &kp C_BRI_INC,      LT4 LT3 LT2,        BASE,              100, 120)
    COMBO(F1,                &kp C_BRI_DEC,      LM4 LM3 LM2,        BASE,              100, 120)
    COMBO(tab,               &kp TAB,            LM2 LM1,            BASE,              60,  0)
    COMBO(cmd_tab,           &kp LG(TAB),        LM3 LM2 LM1,        BASE,              100, 0, slow-release;)
    COMBO(tick,              &kp GRAVE,          LB2 LB1,            BASE,              80,  0)
    COMBO(cmd_tick,          &kp LG(GRAVE),      LB3 LB2 LB1,        BASE,              100, 0, slow-release;)
    COMBO(caps_word,         &caps_word,         LT4 LT3,            BASE,              50,  0)
    COMBO(lctl_other,        &kp LCTRL,          LM1 LM0,            BASE,              50,  80)

    /* LEFT-HAND VERTICAL */
    COMBO(l_lctl,              &kp LCTRL,          LM3 LB3,            BASE,              80,  0)
    COMBO(l_lalt,              &kp LALT,           LM2 LB2,            BASE,              80,  0)
    COMBO(l_lgui,              &kp LGUI,          LM1 LB1,            BASE,              80,  0)

    /* RIGHT-HAND HORIZONTAL */
    COMBO(scln,              &kp SEMI,           RM1 RM2,            BASE,              60,  0)

    /* RIGHT-HAND VERTICAL */
    COMBO(r_lctl,              &kp RCTRL,          RM3 RB3,            BASE,              80,  0)
    COMBO(r_lalt,              &kp RALT,           RM2 RB2,            BASE,              80,  0)
    COMBO(r_lgui,              &kp RGUI,          RM1 RB1,            BASE,              80,  0)

  };
};

